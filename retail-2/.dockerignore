.env
.env.local
.env.*.local

# Version control
.git
.gitignore

# Dev tooling
.eslintcache
*.log
npm-debug.log*

# OS artifacts
.DS_Store
Thumbs.db

# Test / coverage
coverage
__tests__
*.test.ts
*.spec.ts
