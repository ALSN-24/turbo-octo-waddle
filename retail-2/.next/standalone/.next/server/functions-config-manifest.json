{
  "version": 1,
  "functions": {
    "/_middleware": {
      "runtime": "nodejs",
      "matchers": [
        {
          "regexp": "^(?:\\/(_next\\/data\\/[^/]{1,}))?(?:\\/((?!_next\\/static|_next\\/image|favicon.ico|\\/favicon.ico|uploads\\/|\\/uploads\\/|.*.(?:svg|png|jpg|jpeg|gif|webp)$).*))(\\.json|\\.rsc|\\.segments\\/.+\\.segment\\.rsc)?[\\/#\\?]?$",
          "originalSource": "/((?!_next/static|_next/image|favicon.ico|/favicon.ico|uploads/|/uploads/|.*.(?:svg|png|jpg|jpeg|gif|webp)$).*)"
        }
      ]
    }
  }
}