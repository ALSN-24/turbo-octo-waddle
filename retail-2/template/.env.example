# ============================================================
# Retail CRM v3 — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
#
# AWS deployments: store secrets in AWS Secrets Manager and
# reference them by ARN in your App Runner or ECS task
# definition. See AWS_DEPLOY.md for full instructions.
# ============================================================

# ── MySQL / RDS database connection ─────────────────────────
# Local dev: localhost
# AWS RDS:   your-instance.xxxx.us-east-1.rds.amazonaws.com
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=crm
# REQUIRED — must not be empty. Use AWS Secrets Manager in production.
MYSQL_PASSWORD=change_me_strong_password
MYSQL_DATABASE=retail_crm

# For docker-compose only (root password for healthcheck)
MYSQL_ROOT_PASSWORD=change_me_root_password

# ── JWT session signing secret ──────────────────────────────
# REQUIRED — generate with: openssl rand -base64 32
# Store in AWS Secrets Manager in production.
JWT_SECRET=replace_with_a_long_random_secret

# ── Registration gate ───────────────────────────────────────
# Set to false for production deployments.
# When false, POST /api/auth/register returns 403.
# Create accounts via: npx tsx scripts/create-admin.ts
ALLOW_REGISTRATION=false

# ── Logging ─────────────────────────────────────────────────
# Levels: trace | debug | info | warn | error | fatal
# In production (CloudWatch / Datadog), JSON lines are emitted at this level.
LOG_LEVEL=info
