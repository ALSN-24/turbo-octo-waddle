# ============================================================
# Retail CRM v3 � Docker Compose Environment Variables
# ============================================================

# -- MySQL / RDS database connection -------------------------
# Local development: use localhost when MySQL runs on your host machine.
# Docker Compose uses the `db` service hostname inside the app container.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=crm
MYSQL_PASSWORD=crm_password_dev
MYSQL_DATABASE=retail_crm

# For docker-compose only (root password for healthcheck)
MYSQL_ROOT_PASSWORD=root_password_dev

# -- JWT session signing secret ------------------------------
JWT_SECRET=dev_jwt_secret_32_chars_minimum_length_required_here_12345

# -- Registration gate ---------------------------------------
ALLOW_REGISTRATION=true

# -- Logging -------------------------------------------------
LOG_LEVEL=info
